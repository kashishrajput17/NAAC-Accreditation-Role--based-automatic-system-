# Example Environment Configuration for NAAC Automation System

# Backend Required Properties
JWT_SECRET_KEY=super-secret-jwt-deployment-key-12345
# SQLite is the default, placed in 'instance' folder mapping out to docker volumes
DATABASE_URL=sqlite:///naac.db

# Frontend Settings (Used in .env of Vite app optionally, or implicitly requested)
VITE_API_URL=http://localhost:5000
